# bot - Environment Variables
# Copy this file to .env and fill in your API keys


# Cartesia (STT/TTS)
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# Deepgram (STT/TTS)
DEEPGRAM_API_KEY=


# OpenAI (STT/LLM/TTS/Realtime)
OPENAI_API_KEY=
OPENAI_MODEL=

# Pipecat Audio Metrics bridge (optional).
# WebSocket of the metrics app; use the metrics machine's LAN address if the
# bot runs on a different machine. Events are dropped silently if unreachable.
AUDIO_METRICS_WS_URL=ws://localhost:8123

